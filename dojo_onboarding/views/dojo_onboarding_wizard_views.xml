<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ── Onboarding Wizard Form View ──────────────────────────────────── -->
    <record id="view_dojo_onboarding_wizard_form" model="ir.ui.view">
        <field name="name">dojo.onboarding.wizard.form</field>
        <field name="model">dojo.onboarding.wizard</field>
        <field name="arch" type="xml">
            <form string="New Member Onboarding">

                <!-- Progress header -->
                <div class="alert alert-info py-2 mb-3 mx-3" role="status">
                    <!-- Parent-only path: Member Info > Household > Payment > Portal Access -->
                    <span invisible="step != 'member_info' or role != 'parent'">
                        <b>Step 1:</b> Member Info  ›  Household  ›  Payment  ›  Portal Access
                    </span>
                    <span invisible="step != 'household' or role != 'parent'">
                        ✓ Member Info  ›  <b>Step 2: Household</b>  ›  Payment  ›  Portal Access
                    </span>
                    <span invisible="step != 'payment' or role != 'parent'">
                        ✓ Member Info  ›  ✓ Household  ›  <b>Step 3: Payment</b>  ›  Portal Access
                    </span>
                    <span invisible="step != 'portal_access' or role != 'parent'">
                        ✓ Member Info  ›  ✓ Household  ›  ✓ Payment  ›  <b>Step 4: Portal Access</b>
                    </span>
                    <!-- 6-step path: creating a new household (student / both roles) -->
                    <span invisible="step != 'member_info' or not create_new_household or role == 'parent'">
                        <b>Step 1:</b> Member Info  ›  Household  ›  Guardian Setup  ›  Enrollment  ›  Auto-Enroll  ›  Subscription  ›  Portal Access
                    </span>
                    <span invisible="step != 'household' or not create_new_household or role == 'parent'">
                        ✓ Member Info  ›  <b>Step 2: Household</b>  ›  Guardian Setup  ›  Enrollment  ›  Auto-Enroll  ›  Subscription  ›  Portal Access
                    </span>
                    <span invisible="step != 'guardian_setup'">
                        ✓ Member Info  ›  ✓ Household  ›  <b>Step 3: Guardian Setup</b>  ›  Enrollment  ›  Auto-Enroll  ›  Subscription  ›  Portal Access
                    </span>
                    <span invisible="step != 'enrollment' or not create_new_household">
                        ✓ Member Info  ›  ✓ Household  ›  ✓ Guardian Setup  ›  <b>Step 4: Enrollment</b>  ›  Auto-Enroll  ›  Subscription  ›  Portal Access
                    </span>
                    <span invisible="step != 'auto_enroll' or not create_new_household">
                        ✓ Member Info  ›  ✓ Household  ›  ✓ Guardian Setup  ›  ✓ Enrollment  ›  <b>Step 4b: Auto-Enroll</b>  ›  Subscription  ›  Portal Access
                    </span>
                    <span invisible="step != 'subscription' or not create_new_household">
                        ✓ Member Info  ›  ✓ Household  ›  ✓ Guardian Setup  ›  ✓ Enrollment  ›  ✓ Auto-Enroll  ›  <b>Step 5: Subscription</b>  ›  Portal Access
                    </span>
                    <span invisible="step != 'portal_access' or not create_new_household or role == 'parent'">
                        ✓ Member Info  ›  ✓ Household  ›  ✓ Guardian Setup  ›  ✓ Enrollment  ›  ✓ Auto-Enroll  ›  ✓ Subscription  ›  <b>Step 6: Portal Access</b>
                    </span>
                    <!-- 5-step path: joining an existing household -->
                    <span invisible="step != 'member_info' or create_new_household">
                        <b>Step 1:</b> Member Info  ›  Household  ›  Enrollment  ›  Auto-Enroll  ›  Subscription  ›  Portal Access
                    </span>
                    <span invisible="step != 'household' or create_new_household">
                        ✓ Member Info  ›  <b>Step 2: Household</b>  ›  Enrollment  ›  Auto-Enroll  ›  Subscription  ›  Portal Access
                    </span>
                    <span invisible="step != 'enrollment' or create_new_household">
                        ✓ Member Info  ›  ✓ Household  ›  <b>Step 3: Enrollment</b>  ›  Auto-Enroll  ›  Subscription  ›  Portal Access
                    </span>
                    <span invisible="step != 'auto_enroll' or create_new_household">
                        ✓ Member Info  ›  ✓ Household  ›  ✓ Enrollment  ›  <b>Step 3b: Auto-Enroll</b>  ›  Subscription  ›  Portal Access
                    </span>
                    <span invisible="step != 'subscription' or create_new_household">
                        ✓ Member Info  ›  ✓ Household  ›  ✓ Enrollment  ›  ✓ Auto-Enroll  ›  <b>Step 4: Subscription</b>  ›  Portal Access
                    </span>
                    <span invisible="step != 'portal_access' or create_new_household">
                        ✓ Member Info  ›  ✓ Household  ›  ✓ Enrollment  ›  ✓ Auto-Enroll  ›  ✓ Subscription  ›  <b>Step 5: Portal Access</b>
                    </span>
                </div>

                <field name="step" invisible="1"/>

                <!-- ── Step 1: Member Info ──────────────────────────────── -->
                <group string="Member Information" invisible="step != 'member_info'">
                    <group>
                        <field name="name" string="Full Name *" placeholder="Full name"/>
                        <field name="email" string="Email *" placeholder="email@example.com"/>
                        <field name="phone" string="Phone *" placeholder="e.g. +1 555 000 0000"/>
                    </group>
                    <group>
                        <field name="role"/>
                        <field name="date_of_birth"/>
                    </group>
                    <group colspan="2">
                        <field name="emergency_note"
                               placeholder="Allergies, medical conditions, emergency notes…"
                               widget="text"/>
                    </group>
                </group>

                <!-- ── Step 2: Household ────────────────────────────────── -->
                <group string="Household Assignment" invisible="step != 'household'">
                    <group>
                        <field name="create_new_household"/>
                    </group>

                    <!-- Existing household path -->
                    <group invisible="create_new_household">
                        <field name="household_id"
                               string="Household *"
                               placeholder="Search for an existing household"/>
                    </group>
                    <group string="Guardian Link (optional)"
                           invisible="create_new_household or role == 'parent'">
                        <field name="guardian_member_id"
                               domain="[('role', 'in', ['parent', 'both'])]"/>
                    </group>
                    <group invisible="create_new_household or not guardian_member_id">
                        <field name="guardian_relation"/>
                    </group>

                    <!-- New household hint -->
                    <div class="alert alert-info py-2 px-3" colspan="2"
                         invisible="not create_new_household or role in ('both', 'parent')" role="alert">
                        <i class="fa fa-arrow-right me-2" title="Next"/>
                        Click <b>Next</b> to enter the guardian's details and set up the household.
                    </div>
                    <div class="alert alert-info py-2 px-3" colspan="2"
                         invisible="not create_new_household or role != 'both'" role="alert">
                        <i class="fa fa-home me-2" title="Household"/>
                        A household will be created for you — you are your own guardian.
                        Click <b>Next</b> to continue to program enrollment.
                    </div>
                    <div class="alert alert-info py-2 px-3" colspan="2"
                         invisible="not create_new_household or role != 'parent'" role="alert">
                        <i class="fa fa-home me-2" title="Household"/>
                        A household will be created for you as the account holder.
                        Click <b>Next</b> to set up a payment method.
                    </div>
                </group>

                <!-- ── Step 3 (new household only): Guardian Setup ───────── -->
                <group string="Guardian Details" invisible="step != 'guardian_setup'">
                    <group>
                        <field name="new_guardian_name"
                               string="Full Name *"
                               placeholder="Full name"/>
                        <field name="new_guardian_email"
                               string="Email *"
                               placeholder="email@example.com"/>
                        <field name="new_guardian_phone"
                               string="Phone *"
                               placeholder="e.g. +1 555 000 0000"/>
                    </group>
                    <group>
                        <field name="new_guardian_role"/>
                        <field name="new_household_name"
                               placeholder="Auto-generated from guardian name if left blank"/>
                    </group>
                    <group>
                        <field name="guardian_relation" string="Relation *"/>
                    </group>
                    <div class="alert alert-info py-2 px-3" colspan="2" role="alert">
                        <i class="fa fa-credit-card me-2" title="Payment"/>
                        A payment method will be collected in the next steps to set up recurring billing.
                    </div>
                </group>

                <!-- ── Step 4: Program Enrollment ───────────────────────── -->
                <group string="Program Enrollment" invisible="step != 'enrollment'">
                    <group>
                        <field name="program_id"
                               string="Program *"
                               placeholder="Select a program…"/>
                    </group>
                    <div class="alert alert-warning py-2 px-3" invisible="program_id"
                         colspan="2" role="alert">
                        <i class="fa fa-exclamation-circle me-2" title="Warning"/>
                        A program is required to continue.
                    </div>
                    <div class="alert alert-info py-2 px-3" invisible="not program_id"
                         colspan="2" role="alert">
                        <i class="fa fa-info-circle me-2" title="Info"/>
                        Select the class rosters this member attends. Once rosters are chosen,
                        you can optionally pre-register them in specific upcoming sessions from those rosters.
                    </div>
                    <group colspan="2" invisible="not program_id">
                        <field name="template_ids" widget="many2many_tags"
                               string="Classes *"
                               domain="[('program_id', '=', program_id)]"
                               placeholder="Add to class rosters for this program…"
                               help="Add this member to recurring class template rosters. The next step lets you choose which days to auto-enrol."/>
                    </group>
                    <group colspan="2" invisible="not template_ids">
                        <field name="session_ids" widget="many2many_tags"
                               string="Specific Sessions"
                               domain="[('state', '=', 'open'), ('template_id', 'in', template_ids)]"
                               placeholder="Optionally pick specific upcoming sessions from the selected rosters…"/>
                    </group>
                </group>

                <!-- ── Step 4b: Auto-Enroll Schedule ────────────────────── -->
                <group string="Auto-Enroll Schedule" invisible="step != 'auto_enroll'">
                    <div class="alert alert-info small py-1 px-2 mb-2" colspan="2" role="alert">
                        <i class="fa fa-calendar-check-o me-1" title="Schedule"/>
                        The system can automatically enroll this member into recurring sessions.
                        Choose which days of the week they are available.
                        Leave all days un-ticked to always enroll on every day the class runs.
                    </div>
                    <group>
                        <field name="auto_enroll_active" widget="boolean_toggle"
                               string="Enable Auto-Enroll"/>
                        <field name="auto_enroll_mode" invisible="not auto_enroll_active"/>
                    </group>
                    <group string="Preferred Days" invisible="not auto_enroll_active">
                        <group>
                            <field name="auto_enroll_mon"/>
                            <field name="auto_enroll_tue"/>
                            <field name="auto_enroll_wed"/>
                            <field name="auto_enroll_thu"/>
                        </group>
                        <group>
                            <field name="auto_enroll_fri"/>
                            <field name="auto_enroll_sat"/>
                            <field name="auto_enroll_sun"/>
                        </group>
                    </group>
                    <group string="Date Range"
                           invisible="not auto_enroll_active or auto_enroll_mode != 'multiday'">
                        <field name="auto_enroll_date_from" string="From *"/>
                        <field name="auto_enroll_date_to" string="To *"/>
                    </group>
                    <div class="text-muted small ps-1" invisible="auto_enroll_active" colspan="2">
                        Auto-enroll is disabled. The member will not be automatically enrolled
                        in recurring sessions — they can still sign up for individual sessions
                        through the portal.
                    </div>
                </group>

                <!-- ── Step 5: Subscription ──────────────────────────────── -->
                <group string="Subscription Plan" invisible="step != 'subscription'">
                    <group>
                        <field name="plan_id"
                               string="Subscription Plan *"
                               domain="['|', '&amp;', ('plan_type', '=', 'program'), ('program_id', '=', program_id), ('plan_type', '=', 'course')]"
                               placeholder="Select a subscription plan…"/>
                        <field name="subscription_start_date" invisible="not plan_id"/>
                    </group>
                    <div class="alert alert-warning py-2 px-3" invisible="plan_id"
                         colspan="2" role="alert">
                        <i class="fa fa-exclamation-circle me-2" title="Warning"/>
                        A subscription plan is required to continue.
                        Only plans compatible with the selected program are shown.
                    </div>
                    <group string="Billing Summary" invisible="not plan_id" colspan="2">
                        <field name="plan_currency_id" invisible="1"/>
                        <field name="plan_initial_fee"
                               widget="monetary"
                               options="{'currency_field': 'plan_currency_id'}"
                               readonly="1"/>
                        <field name="plan_price"
                               widget="monetary"
                               options="{'currency_field': 'plan_currency_id'}"
                               readonly="1"/>
                        <field name="plan_billing_period" readonly="1"/>
                        <field name="plan_sessions_per_period" readonly="1"
                               invisible="plan_unlimited_sessions"/>
                        <field name="plan_unlimited_sessions" invisible="1"/>
                        <div class="text-muted small" invisible="not plan_unlimited_sessions" colspan="2">
                            Unlimited sessions included per billing period.
                        </div>
                        <field name="plan_description" readonly="1" widget="text"
                               invisible="not plan_description"/>
                    </group>
                    <div class="alert alert-info py-2 px-3"
                         invisible="not plan_id or not create_new_household"
                         colspan="2" role="alert">
                        <i class="fa fa-credit-card me-2" title="Payment"/>
                        A payment method will be collected on the next step.
                        Your card will be invoiced for the enrollment fee and the recurring subscription fee.
                    </div>
                    <div class="alert alert-success py-2 px-3"
                         invisible="not plan_id or create_new_household"
                         colspan="2" role="alert">
                        <i class="fa fa-check-circle me-2" title="Payment on file"/>
                        This household already has a payment method on file. No additional payment setup is needed.
                    </div>
                </group>

                <!-- ── Step 5: Portal Access ─────────────────────────────── -->
                <group string="Portal Access" invisible="step != 'portal_access'">

                    <!-- New member account -->
                    <group string="New Member Account">
                        <field name="create_portal_login"/>
                        <field name="send_welcome_email" invisible="not create_portal_login"/>
                    </group>
                    <div class="alert alert-info" invisible="not create_portal_login" role="alert">
                        A portal account will be created for <b><field name="name" readonly="1" nolabel="1"/></b>
                        using their email as the login.
                        They will receive a password-reset email if "Send Welcome Email" is checked.
                    </div>
                    <div class="alert alert-warning" invisible="create_portal_login" role="alert">
                        No portal login will be created for the new member. They cannot log in until
                        a user account is linked manually from their member profile.
                    </div>

                    <!-- Guardian account (only shown when creating a new household AND member is not their own guardian AND not a parent-only registration) -->
                    <group string="Guardian Account" invisible="not create_new_household or role in ('both', 'parent')">
                        <field name="create_guardian_portal_login"/>
                        <field name="send_guardian_welcome_email"
                               invisible="not create_guardian_portal_login"/>
                    </group>
                    <div class="alert alert-info"
                         invisible="not create_new_household or role in ('both', 'parent') or not create_guardian_portal_login"
                         role="alert">
                        A portal account will also be created for the guardian
                        <b><field name="new_guardian_name" readonly="1" nolabel="1"/></b>
                        using their email as the login. Guardians can view household info,
                        track their children's attendance, and manage billing online.
                    </div>
                    <div class="alert alert-warning"
                         invisible="not create_new_household or role in ('both', 'parent') or create_guardian_portal_login"
                         role="alert">
                        No portal login will be created for the guardian. You can grant access
                        later from the guardian's member profile.
                    </div>

                </group>

                <!-- ── Footer navigation ────────────────────────────────── -->
                <footer>
                    <button name="action_next" type="object" string="Next →"
                            class="btn btn-primary"
                            invisible="step == 'portal_access'"/>
                    <button name="action_confirm" type="object"
                            string="Confirm &amp; Create Member"
                            class="btn btn-primary"
                            invisible="step != 'portal_access'"/>
                    <button name="action_back" type="object" string="← Previous"
                            class="btn btn-secondary"
                            invisible="step == 'member_info'"/>
                    <button special="cancel" string="Cancel" class="btn btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ── Wizard Launch Action ──────────────────────────────────────────── -->
    <record id="action_dojo_onboarding_wizard" model="ir.actions.act_window">
        <field name="name">New Member Onboarding</field>
        <field name="res_model">dojo.onboarding.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{"dialog_size": "large"}</field>
    </record>

</odoo>
