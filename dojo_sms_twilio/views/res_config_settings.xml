<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_twilio" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.twilio</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <!-- Append a Twilio block after all existing blocks in the settings form -->
            <xpath expr="//form/app" position="after">
                <block title="Twilio SMS" id="twilio_sms">
                    <setting string="Twilio Account SID"
                             help="Account SID from your Twilio Console dashboard">
                        <field name="twilio_account_sid"
                               placeholder="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"/>
                    </setting>
                    <setting string="Twilio Auth Token"
                             help="Auth token from your Twilio Console dashboard">
                        <field name="twilio_auth_token" password="True"
                               placeholder="Auth token"/>
                    </setting>
                    <setting string="Twilio From Number"
                             help="Twilio phone number in E.164 format, e.g. +15551234567">
                        <field name="twilio_from_number"
                               placeholder="+15551234567"/>
                    </setting>
                    <setting string="Test Twilio"
                             help="Send a test SMS to the From Number to verify routing">
                        <button name="action_test_twilio_sms"
                                string="Send Test SMS"
                                type="object"
                                class="btn btn-secondary"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
