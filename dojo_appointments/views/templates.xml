<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         Public Trial Booking Page
         ================================================================ -->
    <template id="booking_page" name="Dojo: Book a Free Trial Class">
        <t t-call="website.layout">
            <div class="container py-5" style="max-width: 680px;">
                <h1 class="mb-2">Book a Free Trial Class</h1>
                <p class="text-muted mb-4">
                    Fill in your details below and pick an available session.
                    We'll send you a confirmation email straight away.
                </p>

                <!-- Success banner -->
                <t t-if="success">
                    <div class="alert alert-success" role="alert">
                        <h4 class="alert-heading">You're booked in! 🥋</h4>
                        <p class="mb-0">
                            <t t-if="booked_session">
                                <strong><t t-esc="booked_session.name"/></strong>
                                on <strong><t t-esc="booked_session.start_datetime"/></strong>.
                            </t>
                            Check your inbox for a confirmation email.
                        </p>
                        <hr/>
                        <a href="/dojo/book-trial" class="btn btn-outline-success btn-sm">Book another trial</a>
                    </div>
                </t>

                <!-- Error banner -->
                <t t-if="error">
                    <div class="alert alert-danger" role="alert">
                        <t t-esc="error"/>
                    </div>
                </t>

                <t t-if="not success">
                    <form method="POST" action="/dojo/book-trial" class="needs-validation" novalidate="novalidate">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                        <div class="mb-3">
                            <label for="name" class="form-label fw-semibold">Full Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="name" name="name"
                                   t-att-value="values.get('name', '') if values else ''"
                                   placeholder="e.g. Jane Smith" required="required"/>
                        </div>

                        <div class="mb-3">
                            <label for="email" class="form-label fw-semibold">Email Address <span class="text-danger">*</span></label>
                            <input type="email" class="form-control" id="email" name="email"
                                   t-att-value="values.get('email', '') if values else ''"
                                   placeholder="jane@example.com" required="required"/>
                        </div>

                        <div class="mb-3">
                            <label for="mobile" class="form-label fw-semibold">Mobile Number</label>
                            <input type="tel" class="form-control" id="mobile" name="mobile"
                                   t-att-value="values.get('mobile', '') if values else ''"
                                   placeholder="+61 400 000 000"/>
                        </div>

                        <div class="mb-4">
                            <label for="session_id" class="form-label fw-semibold">Select a Session <span class="text-danger">*</span></label>
                            <t t-if="sessions">
                                <select class="form-select" id="session_id" name="session_id" required="required">
                                    <option value="">— Choose a session —</option>
                                    <t t-foreach="sessions" t-as="session">
                                        <option t-att-value="session.id"
                                                t-att-selected="values and str(values.get('session_id', '')) == str(session.id) or None">
                                            <t t-esc="session.name"/> —
                                            <t t-esc="session.start_datetime"/>
                                            <t t-if="session.capacity">
                                                (<t t-esc="session.capacity - (session.seats_taken or 0)"/> spots left)
                                            </t>
                                        </option>
                                    </t>
                                </select>
                            </t>
                            <t t-else="">
                                <div class="alert alert-warning mt-2" role="alert">
                                    There are no upcoming trial sessions available right now.
                                    Please check back soon or call us to arrange a time.
                                </div>
                            </t>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg"
                                    t-att-disabled="not sessions or None">
                                Confirm My Free Trial
                            </button>
                        </div>

                        <p class="text-muted mt-3" style="font-size: 0.85rem;">
                            By submitting this form you agree to be contacted by us about
                            your trial booking. We won't share your details with third parties.
                        </p>
                    </form>
                </t>
            </div>
        </t>
    </template>
</odoo>
