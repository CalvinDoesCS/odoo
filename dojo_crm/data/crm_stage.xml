<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Dojo CRM pipeline stages.
        sequence values are spaced to allow insertion before/after without conflicts.
    -->
    <record id="crm_stage_new_lead" model="crm.stage">
        <field name="name">New Lead</field>
        <field name="sequence">10</field>
        <field name="is_won" eval="False"/>
    </record>

    <record id="crm_stage_trial_booked" model="crm.stage">
        <field name="name">Trial Booked</field>
        <field name="sequence">20</field>
        <field name="is_won" eval="False"/>
    </record>

    <record id="crm_stage_trial_attended" model="crm.stage">
        <field name="name">Trial Attended</field>
        <field name="sequence">30</field>
        <field name="is_won" eval="False"/>
    </record>

    <record id="crm_stage_offer_made" model="crm.stage">
        <field name="name">Offer Made</field>
        <field name="sequence">40</field>
        <field name="is_won" eval="False"/>
    </record>

    <record id="crm_stage_converted" model="crm.stage">
        <field name="name">Converted</field>
        <field name="sequence">50</field>
        <field name="is_won" eval="True"/>
    </record>
</odoo>
