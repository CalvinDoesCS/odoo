<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- ── OnboardingStripePayment widget template ──────────────────────── -->
    <t t-name="dojo_onboarding_stripe.OnboardingStripePayment">
        <div class="dojo-onboarding-stripe-widget">

            <!-- Loading Stripe -->
            <t t-if="state.status === 'loading'">
                <div class="alert alert-info py-2">
                    <i class="fa fa-spinner fa-spin me-2"/>
                    Loading payment form…
                </div>
            </t>

            <!-- Stripe PaymentElement mount point + Save button -->
            <t t-if="state.status === 'ready' or state.status === 'processing'">
                <div t-ref="stripe-mount" class="py-2"/>
                <div class="mt-2">
                    <button
                        class="btn btn-primary"
                        t-on-click="onSaveCard"
                        t-att-disabled="state.status === 'processing'">
                        <t t-if="state.status === 'processing'">
                            <i class="fa fa-spinner fa-spin me-1"/>Saving…
                        </t>
                        <t t-else="">
                            <i class="fa fa-lock me-1"/>Save Card
                        </t>
                    </button>
                </div>
            </t>

            <!-- Success -->
            <t t-if="state.status === 'done'">
                <div class="alert alert-success py-2">
                    <i class="fa fa-check-circle me-2"/>
                    Payment method saved: <strong t-esc="state.cardDisplay"/>
                </div>
            </t>

            <!-- Error -->
            <t t-if="state.status === 'error'">
                <div class="alert alert-danger py-2">
                    <i class="fa fa-exclamation-circle me-2"/>
                    <span t-esc="state.errorMessage"/>
                </div>
                <button class="btn btn-secondary btn-sm mt-1" t-on-click="onRetry">
                    <i class="fa fa-refresh me-1"/>Try Again
                </button>
            </t>

            <!-- Skip option (always visible unless card already done) -->
            <div class="mt-3 pt-2 border-top" t-if="state.status !== 'done'">
                <div class="form-check">
                    <input
                        type="checkbox"
                        class="form-check-input"
                        id="skip-stripe-payment"
                        t-att-checked="props.record.data.skip_payment"
                        t-on-change="onSkipChange"
                    />
                    <label class="form-check-label text-muted small" for="skip-stripe-payment">
                        Skip — collect payment method later
                    </label>
                </div>
                <div class="text-muted small ps-1 mt-1"
                     t-if="props.record.data.skip_payment">
                    The guardian can add their card at
                    <code>/my/payment_method</code> after signing into the portal.
                    The first invoice will be charged on the subscription start date
                    once a card is on file.
                </div>
            </div>

        </div>
    </t>

</templates>
